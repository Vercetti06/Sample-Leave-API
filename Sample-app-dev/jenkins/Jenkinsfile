pipeline {
    agent any

    environment {
        REGISTRY_USER     = 'vercetti06'
        IMAGE_NAME        = 'api-leave'
        DOCKER_HUB        = credentials('docker-hub-credentials')

        SONAR_PROJECT_KEY = 'Vercetti06_Sample-Leave-API'
        SONAR_ORG_KEY     = 'ercetti06'

        TARGET_FILE       = 'Sample-app-dev/kubernetes-manifests/app/app-deployment.yml'
       // GIT_REPO_URL      = 'https://github.com/Sample-Leave-API.git'

        GIT_REPO_NAME = "Sample-Leave-API"
        GIT_USER_NAME = "Vercetti06"
    }

    stages {
        stage('Checkout') {
      steps {
        checkout([$class: 'GitSCM',
          branches: [[name: 'main']],
          userRemoteConfigs: [[url: "https://github.com/${env.GIT_USER_NAME}/${env.GIT_REPO_NAME}.git"]]
        ])
      }
    }

        stage('Build Docker Image') {
            steps {
                sh "docker build -t ${REGISTRY_USER}/${IMAGE_NAME}:${BUILD_NUMBER} Sample-app-dev/"
            }
        }

        stage('SonarQube Cloud SAST') {
            steps {
                withSonarQubeEnv('SonarQubeCloud') {
                    script {
                        def scannerHome = tool 'SonarScanner'
                        sh """
                            ${scannerHome}/bin/sonar-scanner \
                              -Dsonar.projectKey=${SONAR_PROJECT_KEY} \
                              -Dsonar.organization=${SONAR_ORG_KEY} \
                              -Dsonar.sources=Sample-app-dev/ \
                              -Dsonar.inclusions=**/*.py,**/requirements.txt \
                              -Dsonar.qualitygate.wait=true
                        """
                    }
                }
            }
        }

        stage('Trivy FS Scan') {
            steps {
                sh 'trivy fs --exit-code 0 --severity HIGH,CRITICAL Sample-app-dev'
            }
        }

        stage('Unit & Health Test') {
            steps {
                sh '''
                    echo "Starting test container..."
                    docker run -d --name test-container -p 8001:8000 ${REGISTRY_USER}/${IMAGE_NAME}:${BUILD_NUMBER}

                    echo "Giving application lifecycle initialization room..."
                    sleep 5

                    echo "Verifying service endpoints..."
                    curl -f http://localhost:8001/health

                    echo "Tearing down runtime resources..."
                    docker stop test-container
                    docker rm test-container
                '''
            }
        }

        stage('Trivy Image Scan') {
            steps {
                sh "trivy image --exit-code 0 --severity HIGH,CRITICAL ${REGISTRY_USER}/${IMAGE_NAME}:${BUILD_NUMBER}"
            }
        }

        stage('Push to Docker Hub') {
            steps {
                sh '''
                    echo "$DOCKER_HUB_PSW" | docker login -u "$DOCKER_HUB_USR" --password-stdin
                    docker push ${REGISTRY_USER}/${IMAGE_NAME}:${BUILD_NUMBER}
                '''
            }
        }

        stage('Update Manifest & Push Changes') {
    steps {
        withCredentials([usernamePassword(
            credentialsId: 'github-creds',
            usernameVariable: 'GIT_USER',
            passwordVariable: 'GIT_TOKEN'
        )]) {
            sh """
                sed -i 's|image: ${REGISTRY_USER}/${IMAGE_NAME}:.*|image: ${REGISTRY_USER}/${IMAGE_NAME}:${BUILD_NUMBER}|' ${TARGET_FILE}

                git config user.email "yaswanth.padakandla@gmail.com"
                git config user.name "Vercetti06"

                git add ${TARGET_FILE}
                git commit -m "Update image tracking to build ${BUILD_NUMBER}" || true

                git remote set-url origin https://$GIT_USER:$GIT_TOKEN@github.com/Sample-Leave-API.git
                git push origin HEAD:main
            """
        }
    }
}

    post {
        always {
            sh "docker rmi ${REGISTRY_USER}/${IMAGE_NAME}:${BUILD_NUMBER} || true"
        }
        success {
            echo 'Full pipeline passed successfully! Code scanned, image pushed, and manifest updated inline.'
        }
        failure {
            echo 'Pipeline deployment process broken.'
        }
    }
}
}
