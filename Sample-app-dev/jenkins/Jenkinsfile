pipeline {
    agent any

    stages {
        stage('Build') {
            steps {
                sh 'docker build -t leave-api:${BUILD_NUMBER} Sample-app-dev/'
            }
        }

        stage('Test') {
            steps {
                sh '''
                    docker run -d --name test-container -p 8001:8000 leave-api:${BUILD_NUMBER}
                    sleep 5
                    curl -f http://localhost:8001/health
                    docker stop test-container
                    docker rm test-container
                '''
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                    #minikube image load leave-api:${BUILD_NUMBER}
                    kubectl set image deployment/api-leave-deployment api-leave-container=leave-api:${BUILD_NUMBER}
                    kubectl rollout status deployment/api-leave-deployment
                '''
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully — image built, tested, and deployed.'
        }
        failure {
            echo 'Pipeline failed — check the stage logs above to find exactly where.'
        }
    }
}
