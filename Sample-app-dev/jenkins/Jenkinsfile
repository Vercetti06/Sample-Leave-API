pipeline {
    agent any

     environment {
        MINIKUBE_HOME = '/var/lib/jenkins'
        KUBECONFIG    = '/var/lib/jenkins/.kube/config'
    }

    stages {
        stage('Build') {
            steps {
                sh '''
                    # 1. Point the Jenkins terminal straight inside Minikube's internal Docker daemon
                    eval $(minikube docker-env)
                    
                    # 2. This builds the image DIRECTLY inside the cluster registry
                    docker build -t leave-api:${BUILD_NUMBER} Sample-app-dev/
                '''
            }
        }

        stage('Test') {
            steps {
                sh '''
                    # Point to Minikube's internal engine to find your newly built image
                    eval $(minikube docker-env)
                    docker run -d --name test-container -p 8001:8000 api-leave:${BUILD_NUMBER}
                    sleep 5
                    curl -f http://localhost:8001/health
                    docker stop test-container
                    docker rm test-container
                '''
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                    #minikube image load api-leave:${BUILD_NUMBER}
                    #echo "Waiting 15 seconds for Minikube to fully process and cache the image layers..."
                    #sleep 15
                    kubectl set image deployment/api-leave-deployment api-leave-container=api-leave:${BUILD_NUMBER}
                    kubectl rollout status deployment/api-leave-deployment
                '''
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully — image built, tested, and deployed.'
        }
        failure {
            echo 'Pipeline failed — check the stage logs above to find exactly where.'
        }
    }
}
