pipeline {
    agent any
    
    environment {
        REGISTRY_USER = 'vercetti06'
        IMAGE_NAME    = 'api-leave'
        DOCKER_HUB    = credentials('docker-hub-credentials')
    }

    stages {
        stage('Build & Login') {
            steps {
                sh '''
                    echo "Building the Docker image..."
                    docker build -t ${REGISTRY_USER}/${IMAGE_NAME}:${BUILD_NUMBER} Sample-app-dev/                    
                    echo "Logging into Docker Hub..."
                    echo "$DOCKER_HUB_PSW" | docker login -u "$DOCKER_HUB_USR" --password-stdin
                '''
            }
        }

        stage('Test') {
            steps {
                sh '''
                    echo "Starting test container..."
                    docker run -d --name test-container -p 8001:8000 ${REGISTRY_USER}/${IMAGE_NAME}:${BUILD_NUMBER}
                    
                    echo "Waiting for app to start..."
                    sleep 5
                    
                    echo "Running health check query..."
                    curl -f http://localhost:8001/health
                    
                    echo "Cleaning up test container..."
                    docker stop test-container
                    docker rm test-container
                '''
            }
        }

        stage('Push to Docker Hub') {
            steps {
                sh '''
                    echo "Pushing verified image to cloud registry..."
                    docker push ${REGISTRY_USER}/${IMAGE_NAME}:${BUILD_NUMBER}
                    
                    echo "Cleaning up local images to clear disk space..."
                    docker rmi ${REGISTRY_USER}/${IMAGE_NAME}:${BUILD_NUMBER}
                '''
            }
        }

        stage('Deploy to cluster') {
            steps {
                sh '''
                    echo "Instructing Kubernetes to pull and deploy the new registry image..."
                    kubectl set image deployment/api-leave-deployment api-leave-container=${REGISTRY_USER}/${IMAGE_NAME}:${BUILD_NUMBER}
                    
                    echo "Monitoring deployment progress..."
                    kubectl rollout status deployment/api-leave-deployment
                '''
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully — image built, tested, and deployed.'       
        }
        failure {
            echo 'Pipeline failed — check the stage logs above to find exactly where.'
}
    }
}

