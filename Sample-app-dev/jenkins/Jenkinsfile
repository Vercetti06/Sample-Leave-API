pipeline {
    agent any

    environment {
        // Docker Hub Metadata
        REGISTRY_USER    = 'vercetti06'
        IMAGE_NAME       = 'api-leave'
        DOCKER_HUB       = credentials('docker-hub-credentials')

        // SonarQube Cloud Metadata
        SONAR_PROJECT_KEY = 'Vercetti06_Sample-Leave-API'
        SONAR_ORG_KEY     = 'ercetti06'

        // Target Deployment Manifest Path inside the repo
        TARGET_FILE      = 'Sample-app-dev/kubernetes-manifests/app/app-deployment.yml'
    }

    stages {
        stage('Checkout Source Code') {
            steps {
                // Pulls down entire repository layout
                checkout scm
            }
        }

        stage('Build Docker Image') {
            steps {
                sh "docker build -t ${REGISTRY_USER}/${IMAGE_NAME}:${BUILD_NUMBER} Sample-app-dev/"
            }
        }

        stage('SonarQube Cloud SAST') {
            steps {
                withSonarQubeEnv('SonarQubeCloud') {
                    script {
                        def scannerHome = tool 'SonarScanner'
                        
                        // Targeted scanning: ONLY scans app files (python and text files)
                        sh """
                            ${scannerHome}/bin/sonar-scanner \
                              -Dsonar.projectKey=${SONAR_PROJECT_KEY} \
                              -Dsonar.organization=${SONAR_ORG_KEY} \
                              -Dsonar.sources=Sample-app-dev/ \
                              -Dsonar.inclusions="**/*.py,**/requirements.txt"
                        """
                    }
                }
            }
        }

        stage('Quality Gate (API Polling)') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    script {
                        withSonarQubeEnv('SonarQubeCloud') {
                            echo "Polling SonarQube Cloud API for Quality Gate status..."
                            
                            // Locates the runtime tracking metadata file generated by the scanner step
                            def taskFile = ".scannerwork/report-task.txt"
                            if (!fileExists(taskFile)) {
                                error "SonarQube metadata task file not found!"
                            }
                            
                            def props = readProperties file: taskFile
                            def taskUrl = props['ceTaskUrl']
                            
                            // Poll the background task API until the status switches to SUCCESS
                            def status = "PENDING"
                            while (status == "PENDING" || status == "IN_PROGRESS") {
                                echo "Analysis processing status: ${status}. Waiting 10 seconds..."
                                sleep 10
                                def response = sh(script: "curl -s -u \${SONAR_AUTH_TOKEN}: ${taskUrl}", returnStdout: true).trim()
                                def json = readJSON text: response
                                status = json.task.status
                            }
                            
                            if (status == "SUCCESS") {
                                // Extract the analysis ID profile mapping
                                def response = sh(script: "curl -s -u \${SONAR_AUTH_TOKEN}: ${taskUrl}", returnStdout: true).trim()
                                def json = readJSON text: response
                                def analysisId = json.task.analysisId
                                
                                // Fetch the actual Quality Gate evaluation metric status
                                def gateUrl = "https://sonarcloud.io{analysisId}"
                                def gateResponse = sh(script: "curl -s -u \${SONAR_AUTH_TOKEN}: ${gateUrl}", returnStdout: true).trim()
                                def gateJson = readJSON text: gateResponse
                                def gateStatus = gateJson.projectStatus.status
                                
                                echo "SonarQube Cloud Quality Gate Evaluation: [${gateStatus}]"
                                
                                if (gateStatus == 'ERROR' || gateStatus == 'WARN') {
                                    error "Pipeline aborted! Code failed the SonarQube Quality Gate parameters."
                                }
                            } else {
                                error "SonarQube Cloud background processing execution failed: ${status}"
                            }
                        }
                    }
                }
            }
        }

        stage('Trivy FS Scan') {
            steps {
                // Point Trivy directly the core application files
                sh 'trivy fs --exit-code 0 --severity HIGH,CRITICAL Sample-app-dev/main.py Sample-app-dev/requirements.txt'
            }
        }

        stage('Unit & Health Test') {
            steps {
                sh '''
                    echo "Starting test container..."
                    docker run -d --name test-container -p 8001:8000 ${REGISTRY_USER}/${IMAGE_NAME}:${BUILD_NUMBER}
                    
                    echo "Giving application lifecycle initialization room..."
                    sleep 5
                    
                    echo "Verifying service endpoints..."
                    curl -f http://localhost:8001/health
                    
                    echo "Tearing down runtime resources..."
                    docker stop test-container
                    docker rm test-container
                '''
            }
        }

        stage('Trivy Image Scan') {
            steps {
                sh "trivy image --exit-code 0 --severity HIGH,CRITICAL ${REGISTRY_USER}/${IMAGE_NAME}:${BUILD_NUMBER}"
            }
        }

        stage('Push to Docker Hub') {
            steps {
                sh '''
                    echo "$DOCKER_HUB_PSW" | docker login -u "$DOCKER_HUB_USR" --password-stdin
                    docker push ${REGISTRY_USER}/${IMAGE_NAME}:${BUILD_NUMBER}
                '''
            }
        }

        stage('Update Manifest & Push Changes') {
            steps {
                // Reuses your GitHub Credentials profile to push changes back securely
                withCredentials([usernamePassword(
                    credentialsId: 'github-creds', // GitHub Personal Access Token credential ID
                    usernameVariable: 'GIT_USER',
                    passwordVariable: 'GIT_TOKEN'
                )]) {
                    sh """
                        # 1. Update the image tag in the deployment file locally
                        sed -i "s|image: ${REGISTRY_USER}/${IMAGE_NAME}:.*|image: ${REGISTRY_USER}/${IMAGE_NAME}:${BUILD_NUMBER}|" ${TARGET_FILE}
                    
                        git config user.email "yaswanth.padakandla@gmail.com"
                        git config user.name "Verectti06"
                        
                        # Stage the specific updated manifest file
                        git add ${TARGET_FILE}
                        
                        # Commit change with a [skip ci] tag to prevent an infinite loop build
                        git commit -m "Update image tracking to build ${BUILD_NUMBER} [skip ci]"
                        
                        # Overwrite the remote URL layout to include authentication tokens and push
                        git remote set-url origin https://${GIT_USER}:${GIT_TOKEN}@://github.com
                        git push origin HEAD:main
                    """
                }
            }
        }
    }

    post {
        always {
            // Housekeeping: Removes local artifact footprint to maintain disk hygiene
            sh "docker rmi ${REGISTRY_USER}/${IMAGE_NAME}:${BUILD_NUMBER} || true"
        }
        success {
            echo 'Full pipeline passed successfully! Code scanned, image pushed, and manifest updated inline.'
        }
        failure {
            echo 'Pipeline deployment process broken.'
        }
    }
}
